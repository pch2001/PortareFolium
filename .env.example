# ────────────────────────────────────────────────────────────
# Vercel + SEO 설정
# Vercel 대시보드 → Settings → Environment Variables 에서 값을 확인
# ────────────────────────────────────────────────────────────

# 배포된 사이트 URL
NEXT_PUBLIC_SITE_URL=https://your.vercel.app

# Google Search Console에서 발급받은 인증 코드
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-search-console-code

# NAVER Search Advisor에서 발급받은 인증 코드
NEXT_PUBLIC_NAVER_VERIFICATION=your-naver-search-advisor-code

# ────────────────────────────────────────────────────────────
# Supabase 설정
# Supabase 대시보드 → Settings → API 에서 값을 확인.
# ────────────────────────────────────────────────────────────

# 프로젝트 URL (클라이언트·빌드 타임 공통)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon 키 — 브라우저 런타임 클라이언트용 (RLS 적용, 공개 OK)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service Role 키 — 빌드 타임 전용 (RLS 우회, 절대 공개하지 말 것)
# Vercel 환경변수에 추가할 때 "Preview/Production" 환경에만 등록.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ────────────────────────────────────────────────────────────
# Cloudflare R2 설정
# R2 Object Storage → Account Details → API Tokens 에서 S3 호환 token 발급.
# S3 endpoint / Account ID는 R2 개요 페이지에서 확인.
# ────────────────────────────────────────────────────────────

# Cloudflare Account ID (R2 개요 페이지 우측)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 S3 호환 API token (Access Key ID / Secret Access Key)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 bucket 이름
R2_BUCKET=portarefolium-images

# R2 public URL (bucket Settings → Public access → r2.dev subdomain 활성화 후 발급)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ────────────────────────────────────────────────────────────
# E2E 테스트용 Admin 계정
# Supabase Authentication에 등록된 계정 정보 입력.
# ────────────────────────────────────────────────────────────
E2E_EMAIL="your-e2e-email"
E2E_PASSWORD="your-e2e-password"
