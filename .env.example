# ────────────────────────────────────────────────────────────
# Vercel + SEO 설정
# Vercel 대시보드 → Settings → Environment Variables 에서 값을 확인
# ────────────────────────────────────────────────────────────

# 배포된 사이트 URL
NEXT_PUBLIC_SITE_URL=https://your.vercel.app

# 기본 컬러 스킴 fallback
# DB(site_config.color_scheme)가 없거나 읽기 실패할 때만 사용
NEXT_PUBLIC_COLOR_SCHEME=blue

# 기본 job field fallback
# DB(site_config.job_field)가 없거나 읽기 실패할 때만 사용: game 또는 web
NEXT_PUBLIC_JOB_FIELD=game

# Google Search Console에서 발급받은 인증 코드
NEXT_PUBLIC_GOOGLE_VERIFICATION=your-google-search-console-code

# NAVER Search Advisor에서 발급받은 인증 코드
NEXT_PUBLIC_NAVER_VERIFICATION=your-naver-search-advisor-code

# ────────────────────────────────────────────────────────────
# NextAuth 설정
# 관리자 1인용 email/password credentials 로그인
# AUTH_SECRET 필수 (Auth.js v5 표준)
# 미설정 시 NextAuth가 부팅 단계에서 실패
# ────────────────────────────────────────────────────────────
AUTH_SECRET="your-auth-secret"
AUTH_ADMIN_EMAIL="admin@example.com"
# Next env loader가 raw $를 변수 치환하므로 scrypt 구분자는 \$로 escape.
AUTH_ADMIN_PASSWORD_HASH="scrypt\$your_salt_hex\$your_hash_hex"
# Supabase가 꺼진 상태에서 local next start/push gate가 refuge DB를 읽어야 할 때만 설정.
# Vercel 환경변수에는 절대 등록하지 말 것.
# SQLITE_REFUGE_ALLOW_LOCAL_START=local-dev-only
# E2E는 실행 시 랜덤 비밀번호와 hash를 메모리에서 생성해 로그인 폼을 검증.
# 필요하면 E2E_EMAIL만 설정해 테스트용 관리자 email을 바꿀 수 있음.
# E2E_EMAIL="e2e-admin@example.test"

# ────────────────────────────────────────────────────────────
# Supabase 설정
# Supabase 대시보드 → Settings → API 에서 값을 확인.
# ────────────────────────────────────────────────────────────

# 프로젝트 URL (클라이언트·빌드 타임 공통)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Publishable key - browser runtime client key (RLS applies, public OK)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Legacy anon fallback - keep only during migration
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-legacy-anon-key

# Secret key - server-only key (bypasses RLS, never expose publicly)
# Register in Vercel only for Preview/Production environments.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Legacy service_role fallback - keep only during migration
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key

# ────────────────────────────────────────────────────────────
# Cloudflare R2 설정
# R2 Object Storage → Account Details → API Tokens 에서 S3 호환 token 발급.
# S3 endpoint / Account ID는 R2 개요 페이지에서 확인.
# ────────────────────────────────────────────────────────────

# Cloudflare Account ID (R2 개요 페이지 우측)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 S3 호환 API token (Access Key ID / Secret Access Key)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 bucket 이름
R2_BUCKET=portarefolium-images

# R2 public URL (bucket Settings → Public access → r2.dev subdomain 활성화 후 발급)
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev
