#!/bin/sh
# Husky pre-commit: 스테이지된 파일에 Prettier 자동 적용
# --allow-empty: 삭제만 스테이지된 경우(매칭되는 스테이지 파일 없음)에도 훅 통과
pnpm exec lint-staged --allow-empty

# OMC rule snapshot 동기화 — drift 가 있으면 자동 stage
node scripts/sync-omc-directives.mjs
git add .agents/directives/omc 2>/dev/null || true

# 테스트 스위트 통과 여부 검증 (진행 불가 시 커밋 거부)
pnpm vitest run
